generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  sale
  purchase
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  trxNumber   String          @unique @map("trx_number")
  type        TransactionType
  totalAmount Decimal         @map("total_amount") @db.Decimal(15, 2)
  createdAt   DateTime        @default(now()) @map("created_at")

  details TransactionDetail[]

  @@map("transactions")
}

model TransactionDetail {
  id            String  @id @default(uuid()) @db.Uuid
  transactionId String  @map("transaction_id") @db.Uuid
  // medicineId mengacu ke tabel "medicines" di Inventory Service (database lain).
  // Tidak dibuat foreign key relasi Prisma karena beda database/service.
  medicineId    String  @map("medicine_id") @db.Uuid
  quantity      Int
  price         Decimal @db.Decimal(15, 2)
  subtotal      Decimal @db.Decimal(15, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_details")
}
